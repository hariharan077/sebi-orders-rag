# Copy this file to `.env` and fill in your own local values.
# Do not commit real secrets. Each person who forks this repo must use their own OpenAI API key.

SEBI_ORDERS_RAG_DB_DSN=postgresql://postgres:postgres@localhost:5433/sebi_orders_rag
SEBI_ORDERS_RAG_DATA_ROOT=./sebi-orders-pdfs
SEBI_ORDERS_RAG_OPENAI_API_KEY=your_openai_api_key_here
SEBI_ORDERS_RAG_OPENAI_BASE_URL=
SEBI_ORDERS_RAG_CONTROL_PACK_ROOT=

SEBI_ORDERS_RAG_EMBEDDING_MODEL=text-embedding-3-large
SEBI_ORDERS_RAG_EMBEDDING_DIM=1536
SEBI_ORDERS_RAG_EMBED_BATCH_SIZE=32

SEBI_ORDERS_RAG_LOG_LEVEL=INFO
SEBI_ORDERS_RAG_PHASE4_APP_HOST=127.0.0.1
SEBI_ORDERS_RAG_PHASE4_APP_PORT=8014
